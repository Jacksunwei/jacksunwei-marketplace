#!/usr/bin/env bash
# Bootstrap the workspace: initialize each plugin sub-repo via git submodule
# and check out main in each so commits don't land in detached HEAD.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

require() {
  local cmd="$1" hint="$2"
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "✗ '$cmd' not found. Install it first: $hint" >&2
    exit 1
  fi
}

require git "https://git-scm.com/"
require uv  "https://docs.astral.sh/uv/ (or 'brew install uv')"

echo "→ initializing plugin submodules"
git submodule update --init --recursive

echo "→ checking out main in each plugin (avoid detached HEAD)"
git submodule foreach --quiet '
  if git show-ref --verify --quiet refs/heads/main; then
    git checkout --quiet main
  else
    echo "  ! $displaypath has no local main branch; left at $(git rev-parse --short HEAD)"
  fi
'

echo
echo "✓ all plugin sub-repos present and on main"
echo "  Hint: 'make plugin-status' shows per-plugin sync state."
